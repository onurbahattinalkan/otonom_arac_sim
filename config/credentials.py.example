# =============================================================================
# credentials.py — Central configuration for the IoT Telemetry System
#
# HOW TO FILL IN EACH VALUE
# =============================================================================

# --- AWS IoT Core ---
# AWS Console → IoT Core → Settings → "Device data endpoint"
# Example: "xxxxxxxxxxxxxx-ats.iot.eu-central-1.amazonaws.com"
AWS_IOT_ENDPOINT = ""

# Standard TLS port for AWS IoT Core — do not change unless you use ALPN.
AWS_IOT_PORT = 8883

# A unique name for this MQTT client; must match the IoT Thing name you created.
# AWS Console → IoT Core → Manage → Things → Create Thing → enter name here.
AWS_IOT_CLIENT_ID = ""

# The MQTT topic defined in your IoT Rule (see SQL filter below).
# Example: ""
AWS_IOT_TOPIC = ""

# --- X.509 Certificate Paths (downloaded when you created the IoT Thing) ---
# AWS Console → IoT Core → Manage → Things → Certificates → Create certificate
# Download: AmazonRootCA1.pem, device.cert.pem, device.private.key
CA_CERT_PATH     = "certs/AmazonRootCA1.pem"
CLIENT_CERT_PATH = "certs/device.cert.pem"
PRIVATE_KEY_PATH = "certs/device.private.key"

# --- AWS Kinesis Data Streams ---
# AWS Console → Kinesis → Data Streams → Create data stream → copy stream name.
KINESIS_STREAM_NAME = ""

# --- AWS Credentials (used only for local testing / non-Lambda contexts) ---
# AWS Console → IAM → Users → your user → Security credentials → Access keys.
AWS_ACCESS_KEY_ID     = ""
AWS_SECRET_ACCESS_KEY = ""
AWS_REGION            = ""  # e.g. "eu-central-1"

# --- InfluxDB ---
# InfluxDB Cloud: https://cloud2.influxdata.com  →  Load Data → API Tokens → Generate
# Self-hosted: http://<your-host>:8086  →  Data → API Tokens
INFLUXDB_URL    = ""  # e.g. "https://eu-central-1-1.aws.cloud2.influxdata.com"
INFLUXDB_TOKEN  = ""  # the full API token string
INFLUXDB_ORG    = ""  # InfluxDB Cloud: your account e-mail; self-hosted: org name
INFLUXDB_BUCKET = ""  # the bucket you created to store telemetry data
